#!/usr/local/bin/perl

use strict;
use warnings;

my $line_count = 0;

while (my $line = <STDIN>) {
    $line_count++;

    # Check if line begins with whitespace followed by underscore
    if ($line =~ /^\s+_/) {
        # Extract characters from column 35 (index 34) to the end
        my $substr = substr($line, 34) || '';  # substr is 0-based

if ($substr) {
        printf("%5d|%s", $line_count, $substr) . "\n";
	}
    }
}

# Print total line count at the end
print "Total lines read: $line_count\n";
